SERVICE_NAME=CRUD Operations on PostgresDB
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=crud_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/crud_db?schema=public

CORS_ORIGIN=*
PAYLOAD_LIMIT=1mb

JWT_ACCESS_SECRET=dev-access-secret
JWT_REFRESH_SECRET=dev-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
WEBHOOK_SECRET=demo-webhook-secret

UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
UPLOAD_ALLOWED_TYPES=text/plain,image/png,image/jpeg,application/pdf

EXTERNAL_TIMEOUT_MS=1200
DEBOUNCE_MS=350
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
API_KEY_RATE_LIMIT_MAX=10
THROTTLE_CAPACITY=5
THROTTLE_REFILL_PER_SEC=1
