generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FileRecord {
  id           String   @id @default(uuid())
  originalName String
  storedName   String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}
