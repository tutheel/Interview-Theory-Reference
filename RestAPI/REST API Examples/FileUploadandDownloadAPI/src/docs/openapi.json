{
  "openapi": "3.0.3",
  "info": {
    "title": "FileUploadandDownloadAPI",
    "version": "1.0.0",
    "description": "File upload and download API"
  },
  "servers": [{ "url": "http://localhost:3005" }],
  "paths": {
    "/health": { "get": { "summary": "Health", "responses": { "200": { "description": "OK" } } } },
    "/ready": { "get": { "summary": "Readiness", "responses": { "200": { "description": "Ready" }, "503": { "description": "DB unavailable" } } } },
    "/files": {
      "post": { "summary": "Upload file", "responses": { "201": { "description": "Created" } } },
      "get": { "summary": "List files", "responses": { "200": { "description": "OK" } } }
    },
    "/files/{id}": {
      "get": { "summary": "Download file", "responses": { "200": { "description": "Stream" }, "404": { "description": "Not found" } } },
      "delete": { "summary": "Delete file", "responses": { "204": { "description": "Deleted" } } }
    }
  }
}
