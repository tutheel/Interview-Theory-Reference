generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CatalogItem {
  id          String   @id @default(uuid())
  sku         String   @unique
  name        String
  category    String
  description String
  price       Decimal  @db.Decimal(10,2)
  createdAt   DateTime @default(now())

  @@index([name])
  @@index([category, createdAt])
}
